# IntelGraph Environment Configuration
# Copy this file to .env and fill in your values.

# --- Required ---
INTELGRAPH_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# --- Database ---
# SQLite (default, development)
INTELGRAPH_DB_PATH=intelgraph.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/intelgraph

# --- Redis (optional, for distributed task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- API Keys for Intel Sources (optional — leave empty to disable that source) ---
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=

# --- Notification Channels (optional) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@intelgraph.io
SLACK_WEBHOOK_URL=

# --- Storage ---
INTELGRAPH_STORAGE_PATH=/tmp/intelgraph
INTELGRAPH_REPORT_DIR=/tmp/intelgraph/reports
INTELGRAPH_TOTP_STATE=/tmp/intelgraph/totp_state.json
INTELGRAPH_NOTIFICATION_STATE=/tmp/intelgraph/notification_state.json
INTELGRAPH_INVESTIGATION_STATE=/tmp/intelgraph/investigations.json

# --- Logging ---
INTELGRAPH_LOG_LEVEL=info

# --- Deployment ---
INTELGRAPH_DEPLOYMENT=development
INTELGRAPH_CORS_ORIGINS=*

# --- Distributed Mode ---
INTELGRAPH_DISTRIBUTED_ENABLED=false

# --- API ---
INTELGRAPH_API_READ_AUTH=false
INTELGRAPH_BASE_URL=http://localhost:8000
INTELGRAPH_API_KEY=

# --- Alerting Thresholds ---
INTELGRAPH_ALERT_MEMORY_PCT=90
INTELGRAPH_ALERT_CPU_PCT=95
INTELGRAPH_ALERT_PIPELINE_MULT=3.0

# --- API Key Rotation ---
INTELGRAPH_KEY_GRACE_HOURS=24